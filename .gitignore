# Compiled output
out/
*.class

# Ephemeral per-node download cache (wiped on startup/shutdown; never source)
cache/

# Gradle (wrapper jar/scripts ARE committed; build state is not)
.gradle/
build/

# IntelliJ IDEA (project files are regenerable; source is the source of truth)
.idea/
*.iml

# macOS
.DS_Store

# Generated repo digest (gitingest dump)
digest.txt

# Raw design exports — binary, redundant with the unzipped design_handoff folders
*.zip

# Runtime simulation logs (regenerated on every run).
# The directories themselves are kept via .gitkeep because
# MultipleServentStarter redirects each node's output/error into them.
chord/output/*
chord/error/*
!chord/output/.gitkeep
!chord/error/.gitkeep
kademlia/output/*
kademlia/error/*
!kademlia/output/.gitkeep
!kademlia/error/.gitkeep
